root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# Aligné sur le style Kotlin officiel appliqué par ktlint.
ktlint_code_style = intellij_idea
max_line_length = 120
# Les fonctions @Composable sont en PascalCase par convention Compose.
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{yml,yaml,toml}]
indent_size = 2
